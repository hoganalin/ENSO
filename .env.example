# ============================================================
# ENSO-Frontend-demo  /  環境變數範本
# ============================================================
# 使用方式：
#   cp .env.example .env.local
#   然後依照下方說明填入實際值。
# .env.local 永遠不會進 git（已加在 .gitignore）。
# ------------------------------------------------------------

# ---- 1. EC API（電商前台）----
# 六角學院 EC API base URL 與個人路徑，demo 預設用 rogan
NEXT_PUBLIC_API_BASE=https://ec-course-api.hexschool.io/v2
NEXT_PUBLIC_API_PATH=rogan


# ---- 2. AI Agent Provider ----
# 決定 ShoppingAgent 要用哪個 adapter：
#   mock    離線 mock（預設，永遠能跑，不需 API key）
#   server  走 Next.js Route Handler /api/agent，API key 只留 server（production 推薦）
#   direct  client 端直打 Anthropic，key 會被 bundle 到前端（⚠️ 只用於 local dev）
#
# 沒設 → fallback 到 mock
NEXT_PUBLIC_AGENT_PROVIDER=mock


# ---- 3. Anthropic API Keys ----
#
# (a) 給 server mode 使用 ⭐ 推薦
#     沒有 NEXT_PUBLIC_ 前綴 → 只會在 server 端讀取，不會 bundle 到 client。
#     在 /api/agent route handler 裡被讀取。
#     要申請 key：https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
#
# (b) 給 direct mode 使用 ⚠️ 只限本機開發
#     有 NEXT_PUBLIC_ 前綴 → 會被 bundle 到 client bundle，任何人都看得到。
#     只有在 NEXT_PUBLIC_AGENT_PROVIDER=direct 時才會被用到。
# NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...


# ============================================================
# 切換範例
# ============================================================
# 只想看 mock demo：
#   NEXT_PUBLIC_AGENT_PROVIDER=mock
#
# 想接真實 Claude（推薦，production-ready）：
#   NEXT_PUBLIC_AGENT_PROVIDER=server
#   ANTHROPIC_API_KEY=sk-ant-...
#
# 快速 debug（key 會曝光，不要推 production）：
#   NEXT_PUBLIC_AGENT_PROVIDER=direct
#   NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...
